            "label": "2026-05-26_12-08-37",
            "content": "package main\n\nimport \"fmt\"\n\nfunc show(vet []int, esc int) {\n\tfmt.Printf(\"[ \")\n\tfor i := 0; i < len(vet); i++ {\n\t\tif i==0 {\n\t\t\tif i+1 == esc {\n\t\t\t\tfmt.Printf(\"%d> \", vet[i])\n\t\t\t}\n\t\t}\n\t\tif i!=0 && i+1 == esc {\n\t\t\tfmt.Printf(\"%d> \", vet[i])\n\t\t}\n\t\tif i+1 != esc {\n\t\t\tif vet[i] != 0 {\n\t\t\t\tfmt.Printf(\"%d \", vet[i])\n\t\t\t}\n\t\t}\n\t}\n\tfmt.Printf(\"]\\n\")\n}\n\nfunc find_person(vet []int, size int, esc int) int { //achar o pr\u00f3ximo vivo\n\tdead := 0\n\tpos := (esc + 1) % size\n\tfor vet[pos] == dead {\n\t\tpos = (pos + 1) % size\n\t}\n\treturn pos\n}\n\nfunc main() {\n\tvar size int\n\tvar esc int\n\tfmt.Scanf(\"%d\", &size) // quantidade de pessoas\n\tfmt.Scanf(\"%d\", &esc)  //quem est\u00e1 com a espada\n\tvet := make([]int, size)\n\t// Inicializar o vetor com os n\u00fameros 1 a size\n\tfor i := 0; i < size; i++ {\n\t\tvet[i] = i + 1\n\t}\n\tshow(vet, esc)\n\tqtd := size\n\tfor qtd > 1 {\n\t\tgonna_die := find_person(vet, size, esc-1) \n\t\tvet[gonna_die] = 0\n\t\tesc = find_person(vet, size, gonna_die) +1\n\t\tshow(vet, esc)\n\t\tqtd--\n\t}\n}\n",
            "lines": "53"
        }
    ]
